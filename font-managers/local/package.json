{
    "name": "@vmprint/local-fonts",
    "version": "0.1.0",
    "description": "Local filesystem FontManager for vmprint. Bundles common open-source fonts (Noto, Arimo, Tinos, Cousine, Carlito, Caladea, Courier Prime).",
    "author": "cosmiciron",
    "license": "Apache-2.0",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "tsx": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "assets"
    ],
    "scripts": {
        "build": "npm run clean && tsc",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "@vmprint/contracts": "file:../../contracts",
        "@vmprint/engine": "file:../../engine"
    },
    "devDependencies": {
        "@types/node": "^22.13.1",
        "rimraf": "^6.1.3",
        "tsx": "^4.20.5",
        "typescript": "^5.7.3"
    },
    "publishConfig": {
        "access": "public"
    }
}
