{
  "documentVersion": "1.0",
  "layout": {
    "pageSize": "LETTER",
    "margins": {
      "top": 72,
      "right": 72,
      "bottom": 72,
      "left": 72
    },
    "fontFamily": "Arimo",
    "fontSize": 12,
    "lineHeight": 1.25,
    "showPageNumbers": false
  },
  "fonts": {
    "regular": "Arimo"
  },
  "styles": {
    "h1": {
      "fontSize": 24,
      "fontWeight": "bold",
      "marginBottom": 18,
      "keepWithNext": true
    },
    "h2": {
      "fontSize": 16,
      "fontWeight": "bold",
      "marginTop": 12,
      "marginBottom": 10,
      "keepWithNext": true
    },
    "p": {
      "marginBottom": 12,
      "allowLineSplit": true,
      "orphans": 2,
      "widows": 2
    },
    "blockquote": {
      "paddingLeft": 14,
      "paddingRight": 8,
      "paddingTop": 6,
      "paddingBottom": 6,
      "borderLeftWidth": 2,
      "borderLeftColor": "#1a73e8",
      "marginTop": 8,
      "marginBottom": 8
    }
  },
  "elements": [
    {
      "type": "h1",
      "content": "Overlay Sample Document"
    },
    {
      "type": "p",
      "content": "This page is intentionally simple so overlay examples are easy to read. We use predictable spacing and multiple element types to make bounding boxes visually distinct."
    },
    {
      "type": "h2",
      "content": "Paragraph Flow"
    },
    {
      "type": "p",
      "content": "Custom overlays can be used to highlight specific layout outcomes, inspect pagination behavior, or annotate fixture-specific expectations without changing engine internals."
    },
    {
      "type": "blockquote",
      "content": "Overlays are ideal for fast visual debugging in tests and local development."
    },
    {
      "type": "h2",
      "content": "Page Break"
    },
    {
      "type": "p",
      "content": "The next paragraph forces a page break so we can verify overlays across multiple pages.",
      "properties": {
        "style": {
          "marginBottom": 8
        }
      }
    },
    {
      "type": "p",
      "content": "Page 2 starts here. Overlay hooks should receive the correct page index and dimensions for each page.",
      "properties": {
        "style": {
          "pageBreakBefore": true
        }
      }
    },
    {
      "type": "p",
      "content": "Final paragraph on page two for box highlighting checks."
    }
  ]
}
