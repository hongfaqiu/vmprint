  "elements": [
    {
      "type": "kicker",
      "content": "VMPRINT — A RENEGADE TYPOGRAPHY ENGINE"
    },
    {
      "type": "title",
      "content": "Measured, Not Guessed"
    },
    {
      "type": "manifesto",
      "content": "Precision is not a feature. It is the contract. Every baseline, every break, every soft hyphen emerges from traceable geometry — not approximation, not a browser's best guess. VMPrint does not render; it composes. Given the same document on any machine, in any runtime, in any rebuild: the output is identical. Not close. Identical.",
      "properties": {
        "sourceId": "manifesto-dropcap",
        "dropCap": {
          "enabled": true,
          "lines": 4,
          "gap": 6,
          "characterStyle": {
            "fontFamily": "Tinos",
            "fontWeight": 700,
            "color": "#7a3a52"
          }
        }
      }
    },
    {
      "type": "polyglotLead",
      "content": "",
      "properties": {
        "sourceId": "polyglot-lead"
      },
      "children": [
        { "type": "text", "content": "The same contract holds in Latin, " },
        {
          "type": "text",
          "content": "日本語",
          "properties": { "style": { "fontFamily": "Noto Sans JP", "lang": "ja" } }
        },
        { "type": "text", "content": ", " },
        {
          "type": "text",
          "content": "العربية",
          "properties": { "style": { "fontFamily": "Noto Sans Arabic", "direction": "rtl", "lang": "ar" } }
        },
        { "type": "text", "content": ", and " },
        {
          "type": "text",
          "content": "देवनागरी",
          "properties": { "style": { "fontFamily": "Noto Sans Devanagari", "lang": "hi" } }
        },
        { "type": "text", "content": " — without compromise." }
      ]
    },
    {
      "type": "kicker",
      "content": "THE POLYGLOT CONTRACT",
      "properties": {
        "style": { "pageBreakBefore": true }
      }
    },
    {
      "type": "pageTitle",
      "content": "One Engine. Every Script."
    },
    {
      "type": "cjkManifesto",
      "content": "行送りは偶然ではなく制御である。文字の位置は測定値から導かれ、同じ入力は常に同じページをもたらす。",
      "properties": { "sourceId": "cjk-block" }
    },
    {
      "type": "arabicRibbon",
      "content": "المسافة بين الأسطر ليست تخمينًا — إنها قيمة محسوبة ومعادة الإنتاج في كل مرة، على كل جهاز.",
      "properties": { "sourceId": "arabic-block" }
    },
    {
      "type": "matrix",
      "content": "",
      "children": [
        { "type": "text", "content": "Hyphenation survives mid-sentence script shifts: " },
        {
          "type": "text",
          "content": "extra\u00adordinary com\u00adpos\u00adition",
          "properties": { "style": { "fontFamily": "Tinos", "fontStyle": "italic" } }
        },
        { "type": "text", "content": ", " },
        {
          "type": "text",
          "content": "contre-réforme typographique",
          "properties": { "style": { "fontFamily": "Tinos", "fontStyle": "italic" } }
        },
        { "type": "text", "content": ", and " },
        {
          "type": "text",
          "content": "日本語の行分割",
          "properties": { "style": { "fontFamily": "Noto Sans JP", "lang": "ja" } }
        },
        { "type": "text", "content": " — the compositional contract holds at every boundary." }
      ]
    },
    {
      "type": "thesis",
      "content": "",
      "children": [
        { "type": "text", "content": "If you cannot " },
        {
          "type": "text",
          "content": "measure",
          "properties": { "style": { "fontWeight": "bold" } }
        },
        { "type": "text", "content": " it, you cannot " },
        {
          "type": "text",
          "content": "trust",
          "properties": { "style": { "fontWeight": "bold" } }
        },
        { "type": "text", "content": " it." }
      ]
    }
  ]
