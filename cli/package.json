{
    "name": "@vmprint/cli",
    "version": "0.1.0",
    "description": "Deterministic typesetting CLI for the programmable web. Convert JSON document streams to bit-perfect PDFs.",
    "author": "cosmiciron",
    "license": "Apache-2.0",
    "main": "dist/index.js",
    "bin": {
        "vmprint": "dist/index.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "npm run clean && tsc && npm run bundle-implementations",
        "bundle-implementations": "node scripts/bundle-implementations.mjs",
        "clean": "rimraf dist",
        "dev": "tsx --conditions tsx src/index.ts"
    },
    "dependencies": {
        "@vmprint/context-pdf": "file:../contexts/pdf",
        "@vmprint/engine": "file:../engine",
        "@vmprint/local-fonts": "file:../font-managers/local",
        "commander": "^14.0.3"
    },
    "devDependencies": {
        "@types/node": "^22.13.1",
        "rimraf": "^6.1.3",
        "tsx": "^4.20.5",
        "typescript": "^5.7.3"
    },
    "publishConfig": {
        "access": "public"
    }
}
