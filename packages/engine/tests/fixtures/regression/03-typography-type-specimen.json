    {
      "type": "h2",
      "content": "The Weight Axis — Arimo (wght 400–700)"
    },
    {
      "type": "p",
      "content": "Arimo ships as a variable font with a continuous weight axis from 400 to 700. Requests below 400 clamp to the minimum; requests above 700 clamp to the maximum. The italic axis mirrors the same range."
    },
    {
      "type": "weightLine",
      "content": "100 → clamped to axis minimum 400 (normal)",
      "properties": { "style": { "fontWeight": 100 } }
    },
    {
      "type": "weightLine",
      "content": "300 → clamped to axis minimum 400 (normal)",
      "properties": { "style": { "fontWeight": 300 } }
    },
    {
      "type": "weightLine",
      "content": "400 → axis instance 400 (normal)",
      "properties": { "style": { "fontWeight": 400 } }
    },
    {
      "type": "weightLine",
      "content": "500 → axis instance 500 (normal)",
      "properties": { "style": { "fontWeight": 500 } }
    },
    {
      "type": "weightLine",
      "content": "600 → axis instance 600 (normal)",
      "properties": { "style": { "fontWeight": 600 } }
    },
    {
      "type": "weightLine",
      "content": "700 → axis instance 700 (normal)",
      "properties": { "style": { "fontWeight": 700 } }
    },
    {
      "type": "weightLine",
      "content": "900 → clamped to axis maximum 700 (normal)",
      "properties": { "style": { "fontWeight": 900 } }
    },
    {
      "type": "weightLine",
      "content": "300 italic → clamped to 400 (italic)",
      "properties": { "style": { "fontWeight": 300, "fontStyle": "italic" } }
    },
    {
      "type": "weightLine",
      "content": "500 italic → axis instance 500 (italic)",
      "properties": { "style": { "fontWeight": 500, "fontStyle": "italic" } }
    },
    {
      "type": "weightLine",
      "content": "700 italic → axis instance 700 (italic)",
      "properties": { "style": { "fontWeight": 700, "fontStyle": "italic" } }
    },
    {
      "type": "weightLine",
      "content": "900 italic → clamped to 700 (italic)",
      "properties": { "style": { "fontWeight": 900, "fontStyle": "italic" } }
    },
