{
  "name": "@draft2final/cli",
  "version": "0.1.0",
  "description": "Markdown to bit-perfect PDF compiler powered by the VMPrint deterministic typesetting engine.",
  "author": "cosmiciron",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "draft2final": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"src/formats/**/*.yaml\" dist",
    "dev": "tsx --conditions tsx src/cli.ts",
    "clean": "rimraf dist",
    "test:boundaries": "tsx tests/boundary-guards.ts",
    "test:update-layout-snapshots": "npm run test:boundaries && tsx tests/run-tests.ts --update-layout-snapshots",
    "test": "npm run test:boundaries && tsx tests/run-tests.ts"
  },
  "dependencies": {
    "@vmprint/context-pdf": "file:../contexts/pdf",
    "@vmprint/engine": "file:../engine",
    "@vmprint/local-fonts": "file:../font-managers/local",
    "commander": "^14.0.3",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "copyfiles": "^2.4.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
